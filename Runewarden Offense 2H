<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE MudletPackage>
<MudletPackage version="1.001">
	<ScriptPackage>
		<Script isActive="yes" isFolder="no">
			<name>Runewarden Offense 2H</name>
			<packageName></packageName>
			<script>-- Grounde Runewarden Offense 2H - Workbench

-- ============================================
-- Core tables
-- ============================================

grounde = grounde or {}
grounde.opp = grounde.opp or {}
grounde._lastSend = grounde._lastSend or { s = "", gate = false, timer = nil }

grounde.weapon = grounde.weapon or "sword" -- "sword" | "hammer"

grounde.WEAPON_CMD = {
  sword  = "wield bastard sword",
  hammer = "wield warhammer",
}

grounde.ENVENOM_SWORD_CMD = "envenom bastard sword with curare"

grounde.EMPOWER = {
  -- For now: same priority for hammer/sword
  hammer = { "isaz", "sleizak", "inguz" },
  sword  = { "isaz", "sleizak", "inguz" },
}

-- ============================================
-- Helpers (generic)
-- ============================================

local function trim(s) return (tostring(s or ""):gsub("^%s+",""):gsub("%s+$","")) end

local function titleCaseName(name)
  name = trim(tostring(name or ""))
  -- Normalize Achaea names (letters, digits, apostrophe, hyphen)
  name = name:gsub("[^%w'%-]", "")
  name = name:lower()
  if name.title then return name:title() end
  return (name:gsub("(%a)([%w_']*)", function(a,b) return a:upper()..b end))
end

local function sendOnce(line)
  line = tostring(line or "")
  -- Debounce identical sends for a short window (prevents double-fires from multiple hooks)
  local now = os.clock()
  local last = grounde._lastSend
  if last.s == line and last.t and (now - last.t) &lt; 0.25 then return end
  last.s = line
  last.t = now
  send(line)
end

-- Server-side alias helpers (Achaea SETALIAS)
-- Key point: QUEUE can only queue ONE command. If you queue a slash-chain directly,
-- only the first part is actually queued. So we queue a *server alias name*.
local function setServerAlias(aliasName, cmds)
  aliasName = trim(aliasName)
  if aliasName == "" then return end
  sendOnce(string.format("setalias %s %s", aliasName, table.concat(cmds, "/")))
end

local function execServerAlias(aliasName, mode)
  aliasName = trim(aliasName)
  if aliasName == "" then return end
  if mode == "queue" then
    sendOnce("queue addclearfull full " .. aliasName)
  else
    sendOnce(aliasName)
  end
end

-- Create/refresh a server alias, then either RUN it immediately or QUEUE it (FULL).
-- mode: "run" | "queue"
local function setAndExecServerAlias(aliasName, cmds, mode)
  setServerAlias(aliasName, cmds)
  execServerAlias(aliasName, mode)
end

local function tname()
  if type(_G.target) == "string" and trim(_G.target) ~= "" then return trim(_G.target) end
  return nil
end

local function ensureOpp(t)
  t = titleCaseName(t)
  grounde.opp[t] = grounde.opp[t] or {
    -- tracking/state
    parry = "none",
    fracs = { skull = 0, tendon = 0, ribs = 0, wrist = 0 },
    hpPct = nil,
    hpSeenAt = nil,
    perceived = false,

    -- offense bookkeeping
    prepStep = 1,
    prone = false,
  }
  return grounde.opp[t]
end

local function withWeapon(cmds, wep)
  if not wep or wep == "" then return cmds end
  if grounde.weapon == wep then return cmds end
  local wcmd = grounde.WEAPON_CMD[wep]
  if wcmd and wcmd ~= "" then
    grounde.weapon = wep
    local out = { wcmd }
    for i = 1, #cmds do out[#out+1] = cmds[i] end
    return out
  end
  return cmds
end

-- Builds the empower-priority command(s) for the chosen weapon.
-- Current assumption (per your requirement): a single command to set the priority list.
-- If you later confirm weapon-specific syntax, we can adjust here.
local function empowerCmdsFor(wep)
  local runes = grounde.EMPOWER[wep] or {}
  if #runes == 0 then return {} end
  return { "empower priority set " .. table.concat(runes, " ") }
end

-- ============================================
-- Tracking (ALL tracking functions come before any decision logic)
-- ============================================

-- Tuning knobs (used later by selection logic)
grounde.HARD_CAP  = grounde.HARD_CAP  or 7

-- Fracture stacking policy (configurable)
-- - "stack" phase: bring each zone up to STACK_TARGET in this order, skipping parried zone
-- - once all zones &gt;= STACK_TARGET, continue building by selecting lowest non-parried zone
-- You said: stack each to 4-5 before going higher. Default: 5.
grounde.FRAC_ORDER    = grounde.FRAC_ORDER    or { "head", "legs", "torso", "arms" }
grounde.STACK_TARGET  = grounde.STACK_TARGET  or 5

-- Kill thresholds (configurable)
grounde.BISECT_BELOW  = grounde.BISECT_BELOW  or 45   -- your latest: below 45%
grounde.BRAIN_SKULLS  = grounde.BRAIN_SKULLS  or 5

grounde.DEV_L1 = grounde.DEV_L1 or 2
grounde.DEV_L2 = grounde.DEV_L2 or 4
grounde.DEV_L3 = grounde.DEV_L3 or 6

grounde.DEV_MIN_HP_FOR_L2PLUS = grounde.DEV_MIN_HP_FOR_L2PLUS or 50

-- Utility: normalize parry limb text -&gt; zone
-- Parry normalization
-- We now preserve SIDE information for arms/legs so we can avoid that specific limb.
local function normalizeParry(p)
  p = trim(p or ""):lower()
  if p == "" or p == "none" then return { zone = "none", limb = "none" } end

  if p:find("head") then return { zone = "head", limb = "head" } end
  if p:find("torso") or p:find("chest") or p:find("body") then
    return { zone = "torso", limb = "torso" }
  end
  if p:find("left leg") then return { zone = "legs", limb = "left leg" } end
  if p:find("right leg") then return { zone = "legs", limb = "right leg" } end
  if p:find("left arm") then return { zone = "arms", limb = "left arm" } end
  if p:find("right arm") then return { zone = "arms", limb = "right arm" } end

  -- fallback if something weird
  if p:find("leg") then return { zone = "legs", limb = "unknown leg" } end
  if p:find("arm") then return { zone = "arms", limb = "unknown arm" } end

  return { zone = "none", limb = "none" }
end

function grounde.setParry(person, limbText)
  person = titleCaseName(person)
  local o = ensureOpp(person)
  local info = normalizeParry(limbText)
  o.parry = info.zone
  o.parryLimb = info.limb -- exact limb (left arm, right leg, etc)
  o.perceived = true
end

function grounde.setFracs(person, skull, tendon, ribs, wrist)
  person = titleCaseName(person)
  local o = ensureOpp(person)
  o.fracs.skull  = tonumber(skull  or 0) or 0
  o.fracs.tendon = tonumber(tendon or 0) or 0
  o.fracs.ribs   = tonumber(ribs   or 0) or 0
  o.fracs.wrist  = tonumber(wrist  or 0) or 0
  o.perceived = true
end

function grounde.ingestPerceiveFromAk(person, parryLimbText)
  person = titleCaseName(person)

  grounde.setParry(person, parryLimbText)

  local skull  = ak and ak.twoh and (ak.twoh.skull or ak.twoh.skulls)
  local tendon = ak and ak.twoh and (ak.twoh.tendons or ak.twoh.tendon)
  local ribs   = ak and ak.twoh and (ak.twoh.ribs or ak.twoh.rib)
  local wrist  = ak and ak.twoh and (ak.twoh.wrist or ak.twoh.wrists)

  grounde.setFracs(person, skull or 0, tendon or 0, ribs or 0, wrist or 0)
end

function grounde.setHpPct(person, pct)
  person = titleCaseName(person)
  local o = ensureOpp(person)
  pct = tonumber(pct or 0) or 0
  if pct &lt; 0 then pct = 0 end
  if pct &gt; 100 then pct = 100 end
  o.hpPct = pct
  o.hpSeenAt = os.clock()
end


function grounde.onAssessHp(person, pct)
  -- Always store HP (tracking only). No gate logic here.
  grounde.setHpPct(person, pct)
end

function grounde.getHpPct(person, maxAge)
  person = titleCaseName(person)
  local o = ensureOpp(person)
  if o.hpPct == nil then return nil end
  local age = os.clock() - (o.hpSeenAt or 0)
  local limit = tonumber(maxAge or 8) or 8
  if age &gt; limit then return nil end
  return tonumber(o.hpPct) or nil
end

-- ============================================
-- Limb damage integration (reads from your lb package)
-- ============================================

-- Canonical limb keys expected by most limb trackers / your prompt display
-- NOTE: Your limb tracker stores hits as percentages (0-100+).
grounde.LIMBS = grounde.LIMBS or {
  "head",
  "torso",
  "right arm",
  "left arm",
  "left leg",
  "right leg",
}

-- Safe read of lb table
local function lbHits(person, limb)
  if not lb then return nil end

  -- Different limb systems key targets differently; try a few common variants.
  local tc  = titleCaseName(person)
  local lc  = tc:lower()
  local raw = trim(tostring(person or ""))

  local candidates = { tc, raw, raw:lower(), lc }
  local entry
  for _, k in ipairs(candidates) do
    if k and k ~= "" and type(lb[k]) == "table" then
      entry = lb[k]
      break
    end
  end

  if not entry or type(entry.hits) ~= "table" then return nil end
  return tonumber(entry.hits[limb] or 0) or 0
end

-- Public API: get limb damage percent (0-100+), or nil if unknown
function grounde.getLimbHits(person, limb)
  if not person or not limb then return nil end
  return lbHits(person, limb)
end

-- Thresholds (tune later if your lb package uses different semantics)
grounde.PREP_TARGET = grounde.PREP_TARGET or 95

function grounde.limbIsBroken(person, limb)
  local h = lbHits(person, limb)
  if h == nil then return false end
  return h &gt;= 100
end

function grounde.limbIsPrepped(person, limb)
  local h = lbHits(person, limb)
  if h == nil then return false end
  return h &gt;= (grounde.PREP_TARGET or 95)
end

-- Convenience: both legs broken?
function grounde.legsBroken(person)
  return grounde.limbIsBroken(person, "left leg") and grounde.limbIsBroken(person, "right leg")
end

-- ============================================
-- Decision helpers (these only READ tracking state)
-- ============================================

local function zoneCapped(o, zone)
  if zone == "head"  then return (o.fracs.skull  or 0) &gt;= grounde.HARD_CAP end
  if zone == "legs"  then return (o.fracs.tendon or 0) &gt;= grounde.HARD_CAP end
  if zone == "torso" then return (o.fracs.ribs   or 0) &gt;= grounde.HARD_CAP end
  if zone == "arms"  then return (o.fracs.wrist  or 0) &gt;= grounde.HARD_CAP end
  return false
end

-- (pickFracZone is defined later with stack-to-5 + avoid parry)

-- ============================================
-- Command builders (execution strings)
-- ============================================

grounde.cmd = grounde.cmd or {}

function grounde.cmd.perceive(t) return "battlefury perceive " .. t end
function grounde.cmd.assess(t)  return "assess " .. t end

function grounde.cmd.bf(mode)
  return "battlefury " .. mode
end

-- ============================================
-- Attack builders (real attack catalog)
-- ============================================

-- Each builder returns:
--   atk: string (the command)
--   wep: "hammer"|"sword" (what to wield)
--   meta: table describing what it does (for decision logic)

grounde.attack = grounde.attack or {}

-- Helpers for defenses tracked in AK
local function hasTargetDef(person, def)
  if not ak or not ak.defs then return false end
  person = titleCaseName(person)
  -- common patterns in packs:
  -- 1) ak.defs["shield"] = true (global last-seen target)
  -- 2) ak.defs[person].shield = true (per-target)
  -- 3) ak.defs[person]["shield"] = true
  if type(ak.defs[def]) ~= "nil" then return ak.defs[def] == true end
  local pd = ak.defs[person]
  if type(pd) == "table" then
    if pd[def] == true then return true end
  end
  return false
end

-- Weapon preference resolver:
-- allowed: {hammer=true, sword=true}
-- pref: "hammer"|"sword"
local function pickWeapon(pref, allowed)
  allowed = allowed or { hammer = true, sword = true }
  if pref == "hammer" and allowed.hammer then return "hammer" end
  if pref == "sword"  and allowed.sword  then return "sword"  end
  if allowed.hammer then return "hammer" end
  if allowed.sword  then return "sword"  end
  return grounde.weapon or "sword"
end

-- -------------
-- Core attacks
-- -------------

-- Overhand &lt;target&gt; : hammer or sword (hammer preferred) -&gt; head -&gt; skull fracs
function grounde.attack.overhand(t)
  local wep = pickWeapon("hammer", { hammer = true, sword = true })
  return "overhand " .. t, wep, { zone = "head", frac = "skull", kind = "attack" }
end

-- Underhand &lt;target&gt; : hammer or sword (hammer preferred) -&gt; torso -&gt; ribs
function grounde.attack.underhand(t)
  local wep = pickWeapon("hammer", { hammer = true, sword = true })
  return "underhand " .. t, wep, { zone = "torso", frac = "ribs", kind = "attack" }
end

-- Pulverise &lt;target&gt; &lt;left|right&gt; &lt;arm|leg&gt; : hammer -&gt; arms/legs -&gt; wrist/tendon
function grounde.attack.pulverise(t, side, limb)
  side = trim(side):lower()
  limb = trim(limb):lower() -- "arm"|"leg"
  local zone = (limb == "leg") and "legs" or "arms"
  local frac = (limb == "leg") and "tendon" or "wrist"
  return string.format("pulverise %s %s %s", t, side, limb), "hammer", { zone = zone, frac = frac, kind = "attack" }
end

-- Hew &lt;target&gt; &lt;left|right&gt; &lt;arm|leg&gt; : sword -&gt; arms/legs -&gt; wrist/tendon
function grounde.attack.hew(t, side, limb)
  side = trim(side):lower()
  limb = trim(limb):lower()
  local zone = (limb == "leg") and "legs" or "arms"
  local frac = (limb == "leg") and "tendon" or "wrist"
  return string.format("hew %s %s %s", t, side, limb), "sword", { zone = zone, frac = frac, kind = "attack" }
end

-- Brain &lt;target&gt; : hammer -&gt; killing blow (requires 5 skull fracs; used after battlefury overwhelm)
function grounde.attack.brain(t)
  return "brain " .. t, "hammer", { zone = "head", frac = "skull", kind = "kill", requires = { overwhelm = true, skull = 5 } }
end

-- Devastate &lt;target&gt; &lt;arms|legs&gt; : hammer or sword (hammer preferred)
-- Break levels based on wrist/tendon fracs:
--   L1: 2, L2: 4, L3: 6
-- Policy note (enforced later): use L2+ only if target HP &lt; 50.
function grounde.attack.devastate(t, zone)
  zone = trim(zone):lower() -- "arms"|"legs"
  local wep = pickWeapon("hammer", { hammer = true, sword = true })
  local frac = (zone == "legs") and "tendon" or "wrist"
  return string.format("devastate %s %s", t, zone), wep, { zone = zone, frac = frac, kind = "break" }
end

-- Splinter &lt;target&gt; : warhammer -&gt; breaks shield/rebounding
function grounde.attack.splinter(t)
  return "splinter " .. t, "hammer", { kind = "defbreak", breaks = { "shield", "rebounding" } }
end

-- Carve &lt;target&gt; : sword -&gt; breaks shield/rebounding
function grounde.attack.carve(t)
  return "carve " .. t, "sword", { kind = "defbreak", breaks = { "shield", "rebounding" } }
end

-- Impale &lt;target&gt; : sword -&gt; impales proned target
function grounde.attack.impale(t)
  return "impale " .. t, "sword", { kind = "setup", requires = { prone = true } }
end

-- Disembowel &lt;target&gt; : sword -&gt; massive damage on impaled target
function grounde.attack.disembowel(t)
  return "disembowel " .. t, "sword", { kind = "kill", requires = { impale = true } }
end

-- Bisect &lt;target&gt; : sword -&gt; execute when target HP is low (threshold controlled by grounde.BISECT_BELOW)
function grounde.attack.bisect(t)
  return "bisect " .. t, "sword", { kind = "execute", requires = { hp_below = 45 } }
end

-- -----------------
-- Convenience picks
-- -----------------

-- If shield or rebounding is up, choose the correct breaker for current preferences.
-- Returns nil if no break needed.
function grounde.attack.pickDefBreak(t)
  if not hasTargetDef(t, "shield") and not hasTargetDef(t, "rebounding") then
    return nil
  end
  -- Prefer splinter (hammer) when possible, else carve.
  if grounde.WEAPON_CMD and grounde.WEAPON_CMD.hammer and grounde.WEAPON_CMD.hammer ~= "" then
    return grounde.attack.splinter(t)
  end
  return grounde.attack.carve(t)
end

-- Map a desired fracture zone ("head"|"torso"|"arms"|"legs") to an attack.
-- This is the bridge between pickFracZone() and attack selection.
function grounde.attack.forFracZone(t, zone)
  zone = trim(zone):lower()

  if zone == "head" then
    return grounde.attack.overhand(t)

  elseif zone == "torso" then
    return grounde.attack.underhand(t)

  elseif zone == "arms" then
    -- Choose left/right arm closest to breaking (highest %), avoiding parried limb
    local o = ensureOpp(t)
    local left  = grounde.getLimbHits(t, "left arm") or 0
    local right = grounde.getLimbHits(t, "right arm") or 0

    local parried = o.parryLimb

    -- Prefer the one closer to break (higher value)
    local chosen
    if left &gt;= right then
      chosen = "left"
      if parried == "left arm" then chosen = "right" end
    else
      chosen = "right"
      if parried == "right arm" then chosen = "left" end
    end

    return grounde.attack.pulverise(t, chosen, "arm")

  elseif zone == "legs" then
    -- Choose left/right leg closest to breaking (highest %), avoiding parried limb
    local o = ensureOpp(t)
    local left  = grounde.getLimbHits(t, "left leg") or 0
    local right = grounde.getLimbHits(t, "right leg") or 0

    local parried = o.parryLimb

    local chosen
    if left &gt;= right then
      chosen = "left"
      if parried == "left leg" then chosen = "right" end
    else
      chosen = "right"
      if parried == "right leg" then chosen = "left" end
    end

    return grounde.attack.pulverise(t, chosen, "leg")
  end

  return grounde.attack.overhand(t)
end

-- ============================================
-- Lyre tracking (prismatic barrier)
-- ============================================

function grounde.setLyred(person, isUp)
  person = titleCaseName(person)
  local o = ensureOpp(person)
  o.lyred = (isUp == true)
  o.lyreSeenAt = os.clock()
  -- Optional compatibility with existing trigger packs that still use this global.
  if type(_G.targetlyred) ~= "nil" then
    _G.targetlyred = o.lyred and 1 or 0
  end
end

-- Lyre predicate with safety:
-- 1) Prefer per-target state (o.lyred).
-- 2) If o.lyred is nil, allow a LIMITED fallback to _G.targetlyred, but immediately
--    convert it into per-target state with a timestamp.
-- 3) If maxAge is provided, only trust lyre state if it's recent.
function grounde.isLyred(person, maxAge)
  person = titleCaseName(person)
  local o = ensureOpp(person)

  local function withinAge()
    if not maxAge then return true end
    local age = os.clock() - (o.lyreSeenAt or 0)
    return age &lt;= tonumber(maxAge)
  end

  -- 1) Prefer per-target state.
  if o.lyred ~= nil then
    return (o.lyred == true) and withinAge()
  end

  -- 2) Limited fallback to legacy global, then convert to per-target state.
  if type(_G.targetlyred) == "number" then
    o.lyred = (_G.targetlyred == 1)
    o.lyreSeenAt = os.clock()
    return (o.lyred == true) and withinAge()
  end

  return false
end

-- ============================================
-- Fracture selection (stack-to-5 + avoid parry)
-- ============================================

function grounde.pickFracZone(person)
  person = titleCaseName(person)
  local o = ensureOpp(person)

  local parry = o.parry or "none"
  local fr = {
    head  = (o.fracs.skull  or 0),
    legs  = (o.fracs.tendon or 0),
    torso = (o.fracs.ribs   or 0),
    arms  = (o.fracs.wrist  or 0),
  }

  local function allowed(zone) return zone ~= parry end

  -- STACK phase: follow FRAC_ORDER and bring each zone to STACK_TARGET (default 5)
  for _, z in ipairs(grounde.FRAC_ORDER or {"head","legs","torso","arms"}) do
    if fr[z] &lt; (grounde.STACK_TARGET or 5) and allowed(z) and not zoneCapped(o, z) then
      return z
    end
  end

  -- Post-stack: pick lowest fracture zone (STRICT: never target parried zone)
  -- (Parry only covers one zone; we always choose a different zone for normal attacks.)
  local best, bestVal = nil, 1e9
  for _, z in ipairs({"head","legs","torso","arms"}) do
    if allowed(z) then
      local v = fr[z]
      if v &lt; bestVal then best, bestVal = z, v end
    end
  end
  if best then return best end

  -- Absolute last resort (should not happen): still avoid parry.
  -- If everything non-parried is capped, pick any non-parried zone anyway.
  for _, z in ipairs({"head","legs","torso","arms"}) do
    if allowed(z) then return z end
  end

  return "head"
end

-- ============================================
-- Decision logic
-- ============================================

-- NOTE: These read from your existing trackers:
--   * affstrack.impale ("Me" | false | &lt;other owner&gt;)
--   * affstrack.score.prone (&gt;=100 means prone)
local function proneScore()
  return (affstrack and affstrack.score and tonumber(affstrack.score.prone)) or 0
end

local function isProne() return proneScore() &gt;= 100 end

local function impaleOwner()
  return (affstrack and affstrack.impale) or false
end

local function isImpalingTarget()
  return impaleOwner() == "Me"
end

function grounde.devastateLevel(person, zone)
  person = titleCaseName(person)
  local o = ensureOpp(person)
  zone = trim(zone):lower()
  local n = 0
  if zone == "legs" then n = tonumber(o.fracs.tendon or 0) or 0
  elseif zone == "arms" then n = tonumber(o.fracs.wrist or 0) or 0
  else return 0 end

  if n &gt;= (grounde.DEV_L3 or 6) then return 3 end
  if n &gt;= (grounde.DEV_L2 or 4) then return 2 end
  if n &gt;= (grounde.DEV_L1 or 2) then return 1 end
  return 0
end

local function canUseDevastateL2Plus(person)
  local pct = grounde.getHpPct(person)
  if pct == nil then return false end
  return pct &lt; (grounde.DEV_MIN_HP_FOR_L2PLUS or 50)
end

-- Prefer speed unless the fracs on the targeted zone are 4+.
local function bfForZone(o, zone)
  zone = trim(zone):lower()
  local n = 0
  if zone == "head" then n = tonumber(o.fracs.skull or 0) or 0
  elseif zone == "legs" then n = tonumber(o.fracs.tendon or 0) or 0
  elseif zone == "torso" then n = tonumber(o.fracs.ribs or 0) or 0
  elseif zone == "arms" then n = tonumber(o.fracs.wrist or 0) or 0 end
  if n &gt;= 4 then return "precision" end
  return "speed"
end

-- Returns one of:
--   { exclusive=true, cmd="..." }
--   { wep="hammer|sword", bf="speed|precision|overwhelm", atkCmds={...}, zone="head|legs|torso|arms" }
function grounde.chooseAction(person)
  person = titleCaseName(person)
  local o = ensureOpp(person)

  -- 1) Lyre: sketch othala ONCE per short window to avoid looping on stale flags.
  if grounde.isLyred(person, 6) then
    o._lastOthala = o._lastOthala or 0
    local now = os.clock()
    if (now - o._lastOthala) &gt;= 2.0 then
      o._lastOthala = now
      -- Break the loop: assume othala attempt in-flight until triggers update lyre state again.
      o.lyred = false
      o.lyreSeenAt = now
      return { exclusive = true, cmd = "sketch othala on ground" }
    end
  end

  -- 2) Defbreak (splinter else carve)
  do
    local atk, wep = grounde.attack.pickDefBreak(person)
    if atk then
      -- Defbreaks always use speed (never precision)
      return { wep = wep, bf = "speed", atkCmds = { atk }, zone = "head" }
    end
  end

  -- 3) Kills
  local hp    = grounde.getHpPct(person)
  local skull = tonumber(o.fracs.skull or 0) or 0
  local ribs  = tonumber(o.fracs.ribs  or 0) or 0
  local tend  = tonumber(o.fracs.tendon or 0) or 0

  -- If already impaling: disembowel
  if isImpalingTarget() then
    local dis, wep = grounde.attack.disembowel(person)
    return { wep = wep, bf = bfForZone(o, "torso"), atkCmds = { dis }, zone = "torso" }
  end

  -- If target hp below threshold: bisect
  if hp ~= nil and hp &lt; (grounde.BISECT_BELOW or 45) then
    local bi, wep = grounde.attack.bisect(person)
    return { wep = wep, bf = bfForZone(o, "torso"), atkCmds = { bi }, zone = "torso" }
  end

  -- Skull path: skull &gt;= 5 -&gt; overwhelm + brain (NO devastate)
  if skull &gt;= (grounde.BRAIN_SKULLS or 5) then
    local brain, wepBrain = grounde.attack.brain(person)
    return { wep = wepBrain, bf = "overwhelm", atkCmds = { brain }, zone = "head" }
  end

  -- Rib path: ribs &gt;= 4 -&gt; devastate legs, then impale+disembowel
  if ribs &gt;= 4 then
    local lvl = grounde.devastateLevel(person, "legs")
    if lvl &gt;= 1 and (lvl == 1 or canUseDevastateL2Plus(person)) then
      local dev, _wepDev = grounde.attack.devastate(person, "legs")

      -- You requested: devastate should never be by itself.
      -- Commit to the kill package; if not prone yet, impale/disem may fail but we still send the chain.
      local imp = select(1, grounde.attack.impale(person))
      local dis = select(1, grounde.attack.disembowel(person))
      return { wep = "sword", bf = bfForZone(o, "legs"), atkCmds = { dev, imp, dis }, zone = "legs" }
    end
  end

  -- Tendon L3 available -&gt; PIVOT point:
--   You stated: with an L3 devastate available, we always commit to a KILL route:
--     * Brain route (overwhelm+brain) if skull is ready and skull track is leading
--     * Otherwise impale+disembowel (opponent should be prone for a long time)
  if tend &gt;= (grounde.DEV_L3 or 6) then
    local dev, _wepDev = grounde.attack.devastate(person, "legs")

    local brainNeed = tonumber(grounde.BRAIN_SKULLS or 5) or 5
    local ribNeed   = 4
    local brainScore = skull / brainNeed
    local ribScore   = ribs  / ribNeed

    -- Prefer brain finish only when it is actually available.
    -- Brain route is ALWAYS: overwhelm + brain (NO devastate).
    if skull &gt;= brainNeed and brainScore &gt;= ribScore then
      local brain, wepBrain = grounde.attack.brain(person)
      return { wep = wepBrain, bf = "overwhelm", atkCmds = { brain }, zone = "head" }
    end

    -- Otherwise: commit to impale+disembowel (kill route).
    -- Impale route is ALWAYS: devastate legs + impale + disembowel.
    local imp = select(1, grounde.attack.impale(person))
    local dis = select(1, grounde.attack.disembowel(person))
    return { wep = "sword", bf = bfForZone(o, "legs"), atkCmds = { dev, imp, dis }, zone = "legs" }
  end

  -- 4/5) Parry avoidance + stack-to-5 fracture building
  local zone = grounde.pickFracZone(person)
  local atk, wep, meta = grounde.attack.forFracZone(person, zone)
  local bf = bfForZone(o, meta and meta.zone or zone)
  return { wep = wep, bf = bf, atkCmds = { atk }, zone = (meta and meta.zone) or zone }
end

-- ============================================
-- Option B: two-step execution
--   Step 1: send perceive + assess (balanceless HP probe)
--   Step 2: when BOTH triggers arrive, send wield/empower/envenom/bf/attack/assess
-- ============================================

grounde.pending = grounde.pending or {}

local function ensurePending(t)
  t = titleCaseName(t)
  grounde.pending[t] = grounde.pending[t] or { perceive = false, timer = nil }
  return grounde.pending[t]
end

local function clearPending(t)
  t = titleCaseName(t)
  local p = grounde.pending[t]
  if p and p.timer then killTimer(p.timer) end
  grounde.pending[t] = nil
end

local function isEngagedWith(t)
  t = titleCaseName(t)
  if grounde.engagedTarget and titleCaseName(grounde.engagedTarget) == t then return true end
  return grounde.engaged == true
end

function grounde.startCycle(t)
  t = titleCaseName(t)

  -- Lyre is handled immediately (no perceive/assess).
  -- Safety: only attempt othala once per short window, and clear lyre state locally
  -- so stale flags can't trap us in a loop.
  if grounde.isLyred(t, 6) then
    local o = ensureOpp(t)
    o._lastOthala = o._lastOthala or 0
    local now = os.clock()
    if (now - o._lastOthala) &gt;= 2.0 then
      o._lastOthala = now
      o.lyred = false
      o.lyreSeenAt = now
      sendOnce("sketch othala on ground")
    end
    return
  end

  local p = ensurePending(t)
  p.perceive = false

  -- Timeout safety: if perceive never arrives, clear the gate.
  if p.timer then killTimer(p.timer) end
  p.timer = tempTimer(3.0, function() clearPending(t) end)

  -- Step 1 (server-side alias): engage (if needed) + perceive + assess
  local initCmds = {}
  if not isEngagedWith(t) then
    initCmds[#initCmds+1] = "engage " .. t
  end
  initCmds[#initCmds+1] = grounde.cmd.perceive(t)
  initCmds[#initCmds+1] = grounde.cmd.assess(t)

  -- Use a short alias name (&lt;= 12 chars).
  setAndExecServerAlias("ginit", initCmds, "run")
end

local function bfCmdFor(t, bfmode)
  if bfmode == "overwhelm" then
    return "battlefury overwhelm " .. t
  end
  bfmode = (bfmode == "precision") and "precision" or "speed"
  return "battlefury focus " .. bfmode
end

function grounde.buildAttackSequence(t, decision)
  t = titleCaseName(t)
  local cmds = {}

  local wep = decision.wep or "hammer"
  cmds = withWeapon(cmds, wep)

  local emp = empowerCmdsFor(wep)
  for i = 1, #emp do cmds[#cmds+1] = emp[i] end

  if wep == "sword" then
    cmds[#cmds+1] = grounde.ENVENOM_SWORD_CMD
  end

  cmds[#cmds+1] = bfCmdFor(t, decision.bf)

  for i = 1, #(decision.atkCmds or {}) do
    cmds[#cmds+1] = decision.atkCmds[i]
  end

  cmds[#cmds+1] = grounde.cmd.assess(t)

  return cmds
end

function grounde.tryFinishCycle(t)
  t = titleCaseName(t)
  local p = grounde.pending and grounde.pending[t]
  if not p then return end
  if not p.perceive then return end

  clearPending(t)

  local decision = grounde.chooseAction(t)
  if not decision then return end

  if decision.exclusive then
    sendOnce(decision.cmd)
    return
  end

    -- Server-side queueing (FULL):
  -- IMPORTANT: do NOT queue a slash-chain directly.
  -- Instead, create a server alias that contains the slash-chain, then queue the alias name.
  local cmds = grounde.buildAttackSequence(t, decision)
  setAndExecServerAlias("gatk", cmds, "queue")
end

-- Hooks for your triggers:
-- Call this from your Perceive finalization trigger (Parry or No Parry)
function grounde.onPerceiveDone(person, parryLimbText)
  person = titleCaseName(person)
  grounde.ingestPerceiveFromAk(person, parryLimbText)

  -- IMPORTANT: Only advance the Option-B gate if a cycle is currently active.
  -- This prevents perceive triggers (from target swaps, passive perceives, etc.)
  -- from arming the pending state and causing stray queued attacks later.
  local p = grounde.pending and grounde.pending[person]
  if not p then return end

  p.perceive = true
  grounde.tryFinishCycle(person)
end

-- Call this from your assess parsing trigger ("You glance over ...")
-- It should call grounde.onAssessHp(person, pct)

-- ============================================
-- Start/Stop control (prevents timed/prompt loops)
-- ============================================

grounde.active = grounde.active or false

function grounde.start()
  grounde.active = true
  grounde.offenseStep()
end

function grounde.stop()
  grounde.active = false
  -- clear any pending gates/timers safely
  if grounde.pending then
    for k,_ in pairs(grounde.pending) do
      clearPending(k)
    end
  end
end

-- ============================================
-- Entry points
-- ============================================

function grounde.offenseStep()
  if not grounde.active then return end
  local t = tname()
  if not t then return end
  grounde.startCycle(t)
end

function grounde.perceiveThenOffense()
  if not grounde.active then return end
  local t = tname()
  if not t then return end
  grounde.startCycle(t)
end

